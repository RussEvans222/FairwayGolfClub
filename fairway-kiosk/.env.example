# Salesforce org instance URL
VITE_SF_INSTANCE_URL=https://your-org.my.salesforce.com

# OAuth Connected App client ID (Fairway_Kiosk_App consumer key)
VITE_SF_CLIENT_ID=your_connected_app_consumer_key

# Salesforce login URL
VITE_SF_LOGIN_URL=https://login.salesforce.com

# Direct access token — leave blank; OAuth login handles this at runtime
VITE_SF_ACCESS_TOKEN=

# Bay identity — set per kiosk device (optional)
VITE_BAY_ID=
VITE_BAY_NAME=
