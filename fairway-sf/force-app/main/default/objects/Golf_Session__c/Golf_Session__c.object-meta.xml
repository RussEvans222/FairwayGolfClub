<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Golf Session</label>
    <pluralLabel>Golf Sessions</pluralLabel>
    <description>An actual play or practice session within a Bay Reservation. A reservation may contain more than one session (e.g. range warm-up, then a round).</description>
    <nameField>
        <label>Session Name</label>
        <type>AutoNumber</type>
        <displayFormat>SESS-{0000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>true</enableActivities>
    <enableHistory>false</enableHistory>
    <enableReports>true</enableReports>
</CustomObject>
