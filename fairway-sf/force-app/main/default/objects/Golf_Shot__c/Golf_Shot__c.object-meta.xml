<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Golf Shot</label>
    <pluralLabel>Golf Shots</pluralLabel>
    <description>Universal atomic shot fact, logged for every session type: a practice rep, an in-round shot, or a shot taken during a scored game.</description>
    <nameField>
        <label>Golf Shot Name</label>
        <type>AutoNumber</type>
        <displayFormat>SHOT-{00000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>false</enableActivities>
    <enableHistory>false</enableHistory>
    <enableReports>true</enableReports>
</CustomObject>
